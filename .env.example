# ===========================================
# SHAMANGARO — Production Environment
# ===========================================
# Copy to .env on the VPS and fill in real values.

# --- PostgreSQL (internal Docker network only) ---
POSTGRES_USER=shamangaro
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=shamangaro

# --- Backend (FastAPI — proxied at /backend/) ---
SECRET_KEY=generate-a-64-char-random-string-here
DEBUG=false
DATABASE_URL=postgresql+asyncpg://shamangaro:change_this_strong_password@postgres:5432/shamangaro
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Frontend (public — baked in at Docker build time) ---
NEXT_PUBLIC_SITE_URL=https://shamangaro.com
NEXT_PUBLIC_API_URL=https://shamangaro.com/api

# Internal API URL for server-side fetches inside Docker (not public)
INTERNAL_API_URL=http://backend:8000

# --- CRM V2 — Order notifications & Google Sheets sync ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=SHAMANGARO <orders@shamangaro.com>
ADMIN_NOTIFY_EMAIL=contact@shamangaro.com
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB=Orders
GOOGLE_SERVICE_ACCOUNT_JSON=

# No default admin user — create one after migration (see README):
# docker compose exec backend python -m app.scripts.create_admin --username admin --password 'YourSecurePassword'

# Social media (optional — defaults to shamangaro handles if empty)
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/shamangaro
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/people/Shamangaro/61574339571013/
NEXT_PUBLIC_SOCIAL_TIKTOK=https://tiktok.com/@shamangaro
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@shamangaro

# --- Newsletter — Mailchimp (recommended) ---
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_AUDIENCE_ID=

# --- Newsletter — Resend fallback (if Mailchimp is not configured) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=SHAMANGARO <newsletter@shamangaro.com>
NEWSLETTER_NOTIFY_EMAIL=contact@shamangaro.com
