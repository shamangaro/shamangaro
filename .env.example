# ===========================================
# SHAMANGARO - Environment Configuration
# ===========================================

# PostgreSQL
POSTGRES_USER=shamangaro
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=shamangaro

# Backend
SECRET_KEY=generate-a-64-char-random-string-here
DEBUG=false
DATABASE_URL=postgresql+asyncpg://shamangaro:change_this_strong_password@postgres:5432/shamangaro

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=https://shamangaro.ma

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=1440
